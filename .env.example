# ============================================
# Quini 6 - Variables de entorno
# Copiá este archivo como .env y completalo
# ============================================

# PostgreSQL
POSTGRES_DB=quini
POSTGRES_USER=quini
POSTGRES_PASSWORD=quini_secret

# n8n
N8N_USER=admin
N8N_PASSWORD=admin123

# Telegram Bot
# Obtené el token con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# En producción (ej. Railway): URL pública del webhook para evitar conflicto 409.
# Debe ser la URL completa, ej: https://tu-app.railway.app/telegram-webhook
# Si no la definís, el bot usa polling (solo puede correr una instancia).
TELEGRAM_WEBHOOK_URL=https://tu-dominio.com/telegram-webhook

# Tu Telegram chat ID — acceso a comandos admin (/runcycle, /status)
# Para obtenerlo: mandá cualquier mensaje a @userinfobot en Telegram
ADMIN_TELEGRAM_ID=123123213123123

# Código de invitación para registrarse en el bot (/start CODIGO)
# Dejalo vacío para que sea público
INVITE_CODE=quini2026

# Máximo de tickets activos por usuario
MAX_TICKETS_PER_USER=10
